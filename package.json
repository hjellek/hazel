{
  "name": "hazel-server",
  "version": "5.1.1",
  "main": "dist/lib/index.js",
  "types": "dist/lib/index.d.ts",
  "description": "Lightweight update server for Electron apps",
  "scripts": {
    "lint": "xo",
    "test": "jest",
    "typecheck": "tsc --noEmit",
    "precommit": "lint-staged",
    "clean": "rm -rf dist"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/*.test.ts"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ]
  },
  "license": "MIT",
  "repository": "hjellek/hazel",
  "xo": {
    "extends": [
      "prettier"
    ],
    "rules": {
      "camelcase": 0,
      "new-cap": 0,
      "unicorn/no-process-exit": 0,
      "no-await-in-loop": 0,
      "unicorn/import-index": 0
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "yarn test --findRelatedTests",
      "prettier --single-quote --no-semi --write --no-editorconfig",
      "git add"
    ]
  },
  "dependencies": {
    "async-retry": "1.2.3",
    "date-fns": "1.29.0",
    "express-useragent": "1.0.12",
    "fetch": "1.1.0",
    "finalhandler": "1.1.0",
    "handlebars": "4.0.11",
    "micro": "9.3.3",
    "ms": "2.1.1",
    "node-fetch": "2.0.0",
    "router": "1.3.2",
    "semver": "5.5.0",
    "stream-to-string": "1.1.0",
    "test-listen": "1.1.0",
    "vercel": "44.4.0"
  },
  "devDependencies": {
    "@types/async-retry": "^1.4.9",
    "@types/express": "^5.0.3",
    "@types/express-useragent": "^1.0.5",
    "@types/finalhandler": "^1.2.4",
    "@types/handlebars": "^4.0.40",
    "@types/jest": "^30.0.0",
    "@types/micro": "^7.3.7",
    "@types/ms": "^2.1.0",
    "@types/node": "^24.0.13",
    "@types/node-fetch": "^2.6.12",
    "@types/semver": "^7.7.0",
    "@types/stream-to-string": "^1.1.0",
    "@types/test-listen": "^1.1.2",
    "eslint-config-prettier": "2.9.0",
    "husky": "0.14.3",
    "jest": "^29.7.0",
    "lint-staged": "7.0.0",
    "prettier": "1.10.2",
    "ts-jest": "^29.4.0",
    "typescript": "^5.8.3",
    "xo": "0.20.3"
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
